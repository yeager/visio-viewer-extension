{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "2.0.0",
  "description": "__MSG_extDescription__",
  "default_locale": "en",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "downloads",
    "webNavigation",
    "tabs"
  ],
  "host_permissions": [
    "file:///*",
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["file:///*"],
      "include_globs": ["file:///*.vsdx"],
      "js": ["content-script.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["viewer.html", "jszip.min.js", "libvisio.js"],
      "matches": ["<all_urls>"]
    }
  ]
}