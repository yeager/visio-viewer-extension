{
  "manifest_version": 3,
  "name": "Visio Viewer",
  "version": "1.1.0",
  "description": "View Microsoft Visio (.vsdx) files directly in Chrome using libvisio-ng",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "downloads"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'",
    "sandbox": "sandbox allow-scripts; script-src 'self' 'unsafe-eval' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "sandbox": {
    "pages": ["sandbox.html"]
  },
  "web_accessible_resources": [
    {
      "resources": ["viewer.html", "pyodide/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
