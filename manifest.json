{
  "manifest_version": 3,
  "name": "Visio Viewer",
  "version": "1.0.0",
  "description": "View Microsoft Visio (.vsdx) files directly in Chrome using libvisio-ng",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "downloads"
  ],
  "web_accessible_resources": [
    {
      "resources": ["viewer.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
